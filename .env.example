# Copy to .env.local and adjust.
# Do not put Supabase anon/service keys in client-exposed NEXT_PUBLIC_* vars for DB access.
# The browser talks only to Next.js API routes; Prisma uses the DB URL (+ optional Storage) on the server.

# Supabase PostgreSQL — Transaction pooler (port 6543) for runtime queries.
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (port 5432) — required for prisma migrate; pooler cannot run migrations.
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Local Postgres (no pooler): set both to the same URL, e.g.
# DATABASE_URL="postgresql://user:pass@localhost:5432/webster"
# DIRECT_URL="postgresql://user:pass@localhost:5432/webster"

# Optional: private bucket for kitchen duty photos (signed URLs from API only).
# With these set, sign-up also creates a row in Supabase Auth (Dashboard → Authentication → Users)
# and keeps your app User row id aligned with auth.users.id.
SUPABASE_URL="https://[ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Optional but recommended for login (Dashboard → Settings → API → anon public key).
# If unset, login falls back to the service role client for password checks.
SUPABASE_ANON_KEY="your-anon-key"
# Bucket must be private; create in Dashboard → Storage (same name as below). If uploads error
# with "Bucket not found", create it there or run sql/supabase/004_storage_bucket_duty_photos.sql.
SUPABASE_DUTY_PHOTOS_BUCKET="duty-photos"

# Required for signed session cookies (use a long random string in production).
WEBSTER_JWT_SECRET="replace-with-at-least-32-random-characters"

# Set to 1 so the app uses the API + database instead of localStorage for auth and schedules.
NEXT_PUBLIC_DATABASE_ENABLED=1

# Allow "Admin" on the register page when not running `next dev` (production / next start).
# Development always allows admin signup for testing.
# ALLOW_REGISTER_AS_ADMIN=1

# Production only: set to 1 to auto-create dev bootstrap admins (admin@webster.edu / admin123) on first login/register.
# WEBSTER_BOOTSTRAP_ADMIN=1
