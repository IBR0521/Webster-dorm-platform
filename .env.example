# Copy to .env.local and adjust.

# SQLite (default for local dev). Path is relative to prisma/schema.prisma location.
DATABASE_URL="file:./dev.db"

# Supabase (PostgreSQL): run sql/supabase/001_initial_schema.sql in the SQL editor, then set
# prisma/schema.prisma datasource provider to "postgresql" and use your pooler URL, e.g.:
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# For migrations Prisma often needs direct (port 5432) — see Supabase “Connection string” docs.

# Required for signed session cookies (use a long random string in production).
WEBSTER_JWT_SECRET="replace-with-at-least-32-random-characters"

# Set to 1 so the app uses the API + database instead of localStorage for auth and schedules.
NEXT_PUBLIC_DATABASE_ENABLED=1
